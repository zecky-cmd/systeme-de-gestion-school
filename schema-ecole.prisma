datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model EtablissementConfig {
  id              Int            @id @default(autoincrement())
  anneeActiveId   Int?           @unique
  anneeActive     AnneeScolaire? @relation("AnneeActive", fields: [anneeActiveId], references: [id])
  nom             String         @db.VarChar(150)
  adresse         String?        @db.Text
  telephone       String?        @db.VarChar(20)
  email           String?        @db.VarChar(100)
  logoUrl         String?        @db.VarChar(255)
  devise          String?        @default("FCFA") @db.VarChar(10)
}

enum ModeEval {
  trim
  sem
}

model AnneeScolaire {
  id              Int                   @id @default(autoincrement())
  libelle         String                @db.VarChar(20)
  dateDebut       DateTime              @db.Date
  dateFin         DateTime              @db.Date
  modeEval        ModeEval              @default(trim)
  
  configActive    EtablissementConfig?  @relation("AnneeActive")
  periodes        Periode[]
  classes         Classe[]
  inscriptions    Inscription[]
  rubriquesFinan  RubriqueFinanciere[]
}

enum StatutPeriode {
  ouv
  clos
  arch
}

model Periode {
  id              Int               @id @default(autoincrement())
  anneeId         Int
  annee           AnneeScolaire     @relation(fields: [anneeId], references: [id])
  numero          Int               @db.SmallInt
  libelle         String            @db.VarChar(30)
  dateDebut       DateTime          @db.Date
  dateFin         DateTime          @db.Date
  statut          StatutPeriode     @default(ouv)
  dateCloture     DateTime?
  
  evaluations     Evaluation[]
  bulletins       Bulletin[]
}

enum Cycle {
  col
  lyc
}

model Classe {
  id              Int               @id @default(autoincrement())
  anneeId         Int
  annee           AnneeScolaire     @relation(fields: [anneeId], references: [id])
  nom             String            @db.VarChar(30)
  cycle           Cycle
  niveau          String            @db.VarChar(15)
  serie           String?           @db.VarChar(5)
  salle           String?           @db.VarChar(20)
  capaciteMax     Int               @default(60) @db.SmallInt
  
  inscriptions    Inscription[]
  matieresNiveau  MatiereNiveau[]
}

enum CycleMatiere {
  col
  lyc
  tous
}

model Matiere {
  id              Int               @id @default(autoincrement())
  nom             String            @db.VarChar(80)
  code            String            @unique @db.VarChar(10)
  cycle           CycleMatiere      @default(tous)
  couleur         String?           @db.VarChar(7)
  
  matieresNiveau  MatiereNiveau[]
}

enum RoleUser {
  adm
  dir
  ens
  par
  elv
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique @db.VarChar(150)
  passwordHash        String    @db.VarChar(255)
  role                RoleUser
  estActif            Boolean   @default(true)
  derniereConnexion   DateTime?
  tokenReset          String?   @db.VarChar(255)
  tokenExpiry         DateTime?
  createdAt           DateTime  @default(now())
  
  enseignant          Enseignant?
  eleve               Eleve?
  parent              Parent?
  evaluationsSaisies  Evaluation[]  @relation("EvaluationSaisiePar")
  bulletinsValides    Bulletin[]    @relation("BulletinValidePar")
  paiementsEncaisses  Paiement[]    @relation("PaiementEncaissePar")
  absencesSaisies     Absence[]     @relation("AbsenceSaisiePar")
  sanctionsPrononcees Sanction[]    @relation("SanctionPrononcePar")
  messagesEnvoyes     Message[]     @relation("MessageExpediteur")
  messagesRecus       Message[]     @relation("MessageDestinataire")
  logsActivite        ActivityLog[]
}

enum StatutEnseignant {
  actif
  inact
}

model Enseignant {
  id              Int               @id @default(autoincrement())
  userId          Int               @unique
  user            User              @relation(fields: [userId], references: [id])
  matricule       String?           @unique @db.VarChar(20)
  nom             String            @db.VarChar(80)
  prenom          String            @db.VarChar(80)
  telephone       String?           @db.VarChar(20)
  specialite      String?           @db.VarChar(100)
  statut          StatutEnseignant  @default(actif)
  
  matieresNiveau  MatiereNiveau[]
}

enum Sexe {
  M
  F
}

model Eleve {
  id              Int               @id @default(autoincrement())
  userId          Int?              @unique
  user            User?             @relation(fields: [userId], references: [id])
  matricule       String?           @unique @db.VarChar(20)
  nom             String            @db.VarChar(80)
  prenom          String            @db.VarChar(80)
  dateNaissance   DateTime?         @db.Date
  lieuNaissance   String?           @db.VarChar(100)
  sexe            Sexe
  nationalite     String?           @default("Ivoirienne") @db.VarChar(50)
  photoUrl        String?           @db.VarChar(255)
  
  parents         ParentEleve[]
  inscriptions    Inscription[]
  notes           Note[]
  bulletins       Bulletin[]
  paiements       Paiement[]
  absences        Absence[]
  sanctions       Sanction[]
}

enum LienParent {
  pere
  mere
  tuteur
}

model Parent {
  id              Int               @id @default(autoincrement())
  userId          Int               @unique
  user            User              @relation(fields: [userId], references: [id])
  nom             String            @db.VarChar(80)
  prenom          String            @db.VarChar(80)
  telephone       String?           @db.VarChar(20)
  email           String?           @db.VarChar(150)
  lien            LienParent
  
  eleves          ParentEleve[]
}

model ParentEleve {
  id              Int               @id @default(autoincrement())
  parentId        Int
  parent          Parent            @relation(fields: [parentId], references: [id])
  eleveId         Int
  eleve           Eleve             @relation(fields: [eleveId], references: [id])
  estTuteurLegal  Boolean           @default(false)
  
  @@unique([parentId, eleveId])
}

enum StatutInscription {
  ins
  ab
  exc
}

model Inscription {
  id              Int               @id @default(autoincrement())
  anneeId         Int
  annee           AnneeScolaire     @relation(fields: [anneeId], references: [id])
  eleveId         Int
  eleve           Eleve             @relation(fields: [eleveId], references: [id])
  classeId        Int
  classe          Classe            @relation(fields: [classeId], references: [id])
  statut          StatutInscription @default(ins)
  
  @@unique([anneeId, eleveId])
}

model MatiereNiveau {
  id              Int               @id @default(autoincrement())
  classeId        Int
  classe          Classe            @relation(fields: [classeId], references: [id])
  matiereId       Int
  matiere         Matiere           @relation(fields: [matiereId], references: [id])
  enseignantId    Int
  enseignant      Enseignant        @relation(fields: [enseignantId], references: [id])
  coefficient     Decimal           @default(1.0) @db.Decimal(3,1)
  noteMax         Decimal           @default(20.00) @db.Decimal(4,2)
  
  evaluations     Evaluation[]
  creneaux        Creneau[]
  
  @@unique([classeId, matiereId])
}

enum TypeEvaluation {
  DS
  comp
  interro
}

model Evaluation {
  id              Int               @id @default(autoincrement())
  matiereNiveauId Int
  matiereNiveau   MatiereNiveau     @relation(fields: [matiereNiveauId], references: [id])
  periodeId       Int
  periode         Periode           @relation(fields: [periodeId], references: [id])
  saisiParId      Int
  saisiPar        User              @relation("EvaluationSaisiePar", fields: [saisiParId], references: [id])
  titre           String            @db.VarChar(100)
  type            TypeEvaluation
  dateEvaluation  DateTime          @db.Date
  coefficient     Decimal           @default(1.0) @db.Decimal(3,1)
  noteMax         Decimal           @default(20.00) @db.Decimal(4,2)
  
  notes           Note[]
}

model Note {
  id              Int               @id @default(autoincrement())
  eleveId         Int
  eleve           Eleve             @relation(fields: [eleveId], references: [id])
  evaluationId    Int
  evaluation      Evaluation        @relation(fields: [evaluationId], references: [id])
  valeur          Decimal?          @db.Decimal(4,2)
  estAbsent       Boolean           @default(false)
  appreciation    String?           @db.VarChar(100)
  createdAt       DateTime          @default(now())
  
  @@unique([eleveId, evaluationId])
}

enum MentionBulletin {
  exc
  bien
  pass
  aver
}

model Bulletin {
  id              Int               @id @default(autoincrement())
  eleveId         Int
  eleve           Eleve             @relation(fields: [eleveId], references: [id])
  periodeId       Int
  periode         Periode           @relation(fields: [periodeId], references: [id])
  valideParId     Int
  validePar       User              @relation("BulletinValidePar", fields: [valideParId], references: [id])
  moyenneGenerale Decimal?          @db.Decimal(4,2)
  rang            Int?              @db.SmallInt
  mention         MentionBulletin?
  appreciationGen String?           @db.Text
  estPublie       Boolean           @default(false)
  pdfUrl          String?           @db.VarChar(255)
  datePublication DateTime?
  
  @@unique([eleveId, periodeId])
}

enum JourCreneau {
  lun
  mar
  mer
  jeu
  ven
  sam
}

model Creneau {
  id              Int               @id @default(autoincrement())
  matiereNiveauId Int
  matiereNiveau   MatiereNiveau     @relation(fields: [matiereNiveauId], references: [id])
  jour            JourCreneau
  heureDebut      DateTime          @db.Time
  heureFin        DateTime          @db.Time
  salle           String?           @db.VarChar(20)
  
  absences        Absence[]
}

enum TypeAbsence {
  just
  injust
  retard
}

model Absence {
  id              Int               @id @default(autoincrement())
  eleveId         Int
  eleve           Eleve             @relation(fields: [eleveId], references: [id])
  creneauId       Int?
  creneau         Creneau?          @relation(fields: [creneauId], references: [id])
  saisiParId      Int?
  saisiPar        User?             @relation("AbsenceSaisiePar", fields: [saisiParId], references: [id])
  date            DateTime          @db.Date
  type            TypeAbsence       @default(injust)
  motif           String?           @db.Text
  notifEnvoyee    Boolean           @default(false)
  createdAt       DateTime          @default(now())
}

model RubriqueFinanciere {
  id              Int               @id @default(autoincrement())
  anneeId         Int
  annee           AnneeScolaire     @relation(fields: [anneeId], references: [id])
  libelle         String            @db.VarChar(100)
  montant         Decimal           @db.Decimal(10,0)
  cycle           CycleMatiere      @default(tous)
  estObligatoire  Boolean           @default(true)
  ordre           Int               @default(1) @db.SmallInt
  
  paiements       Paiement[]
}

enum ModePaiement {
  esp
  mobile
  cheque
}

model Paiement {
  id              Int                 @id @default(autoincrement())
  eleveId         Int
  eleve           Eleve               @relation(fields: [eleveId], references: [id])
  rubriqueId      Int
  rubrique        RubriqueFinanciere  @relation(fields: [rubriqueId], references: [id])
  encaisseParId   Int
  encaissePar     User                @relation("PaiementEncaissePar", fields: [encaisseParId], references: [id])
  montant         Decimal             @db.Decimal(10,0)
  datePaiement    DateTime            @default(now())
  mode            ModePaiement
  reference       String?             @db.VarChar(50)
  recuNum         String?             @unique @db.VarChar(20)
  pdfUrl          String?             @db.VarChar(255)
}

enum TypeSanction {
  aver
  excl
  cons
}

model Sanction {
  id              Int               @id @default(autoincrement())
  eleveId         Int
  eleve           Eleve             @relation(fields: [eleveId], references: [id])
  prononceParId   Int
  prononcePar     User              @relation("SanctionPrononcePar", fields: [prononceParId], references: [id])
  type            TypeSanction
  motif           String            @db.Text
  date            DateTime          @db.Date
  dureeJours      Int               @default(0) @db.SmallInt
  createdAt       DateTime          @default(now())
}

model Message {
  id              Int               @id @default(autoincrement())
  expediteurId    Int
  expediteur      User              @relation("MessageExpediteur", fields: [expediteurId], references: [id])
  destinataireId  Int
  destinataire    User              @relation("MessageDestinataire", fields: [destinataireId], references: [id])
  sujet           String            @db.VarChar(200)
  corps           String            @db.Text
  lu              Boolean           @default(false)
  dateEnvoi       DateTime          @default(now())
}

model ActivityLog {
  id              BigInt            @id @default(autoincrement())
  userId          Int
  user            User              @relation(fields: [userId], references: [id])
  action          String            @db.VarChar(60)
  entite          String            @db.VarChar(50)
  entiteId        Int?
  detail          Json?
  ip              String?           @db.VarChar(45)
  createdAt       DateTime          @default(now())
}
